{
  "manifest_version": 3,
  "name": "Save Image as Any Type",
  "version": "1.0.2",
  "description": "Right-click any image to save it as PNG, JPG, or TIFF",
  "permissions": [
    "contextMenus",
    "downloads",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
